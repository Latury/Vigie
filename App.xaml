<Application
    x:Class="Vigie.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="using:Vigie.Infrastructure"
    xmlns:conv2="using:Vigie.Infrastructure.Convertisseurs"
    xmlns:local="using:Vigie">

    <Application.Resources>

        <ResourceDictionary>

            <!--  =====================================================  -->
            <!--  Dictionnaires fusionnés  -->
            <!--  =====================================================  -->

            <ResourceDictionary.MergedDictionaries>

                <!--  Ressources natives WinUI 3  -->
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />

                <!--  =================================================  -->
                <!--  Ressources visuelles globales Vigie  -->
                <!--  =================================================  -->

                <!--  Palette de couleurs officielle  -->
                <ResourceDictionary Source="Ressources/Couleurs/CouleursVigie.xaml" />

                <!--  Dimensions UI standardisées  -->
                <ResourceDictionary Source="Ressources/Dimensions/DimensionsUI.xaml" />

                <!--  Styles globaux des contrôles  -->
                <ResourceDictionary Source="Ressources/Styles/StylesControles.xaml" />

                <!--  Thème principal de l’application  -->
                <ResourceDictionary Source="Ressources/Themes/ThemeBase.xaml" />

            </ResourceDictionary.MergedDictionaries>


            <!--  =====================================================  -->
            <!--  Convertisseurs globaux  -->
            <!--  =====================================================  -->

            <!--  Convertit bool → Visibility  -->
            <conv:ConvertisseurBooleenVersVisibilite x:Key="ConvertisseurBooleenVersVisibilite" />

            <!--  Inverse bool (true ↔ false)  -->
            <conv:ConvertisseurBooleenInverse x:Key="ConvertisseurBooleenInverse" />

            <!--  Statut mise à jour → Couleur UI  -->
            <conv2:StatutMiseAJourCouleurConverter x:Key="ConvertisseurStatutCouleur" />

        </ResourceDictionary>

    </Application.Resources>

</Application>
