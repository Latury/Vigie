<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--  ============================================================  -->
    <!--  1. Espacements UI  -->
    <!--  ============================================================  -->

    <Thickness x:Key="EspacementPetit">4</Thickness>
    <Thickness x:Key="EspacementStandard">8</Thickness>
    <Thickness x:Key="EspacementMoyen">12</Thickness>
    <Thickness x:Key="EspacementLarge">16</Thickness>
    <Thickness x:Key="EspacementSection">24</Thickness>


    <!--  ============================================================  -->
    <!--  2. Dimensions contrôles  -->
    <!--  ============================================================  -->

    <x:Double x:Key="HauteurBoutonStandard">36</x:Double>
    <x:Double x:Key="HauteurChamp">32</x:Double>
    <x:Double x:Key="LargeurBoutonStandard">140</x:Double>


    <!--  ============================================================  -->
    <!--  3. Rayons de bordure  -->
    <!--  ============================================================  -->

    <CornerRadius x:Key="RayonBouton">6</CornerRadius>
    <CornerRadius x:Key="RayonCarte">8</CornerRadius>
    <CornerRadius x:Key="RayonPanneau">10</CornerRadius>


    <!--  ============================================================  -->
    <!--  4. Icônes  -->
    <!--  ============================================================  -->

    <x:Double x:Key="TailleIconeStandard">20</x:Double>
    <x:Double x:Key="TailleIconeLarge">28</x:Double>


    <!--  ============================================================  -->
    <!--  5. Dimensions UI actuelles (navigation principale)  -->
    <!--  ============================================================  -->

    <!--  largeur barre latérale  -->
    <GridLength x:Key="LargeurSidebar">220,0,0,0</GridLength>

    <!--  hauteur bouton navigation  -->
    <x:Double x:Key="HauteurBoutonNavigation">44</x:Double>

    <!--  marge boutons navigation  -->
    <Thickness x:Key="MargeNavigationBouton">20,0</Thickness>

    <!--  marge stackpanel navigation  -->
    <Thickness x:Key="MargeSidebar">0,40,0,0</Thickness>

    <!--  espacement boutons navigation  -->
    <x:Double x:Key="EspacementNavigation">12</x:Double>


    <!--  ============================================================  -->
    <!--  6. Dimensions spécifiques AccueilPage  -->
    <!--  ============================================================  -->

    <!--  Carte état système  -->
    <x:Double x:Key="LargeurCarteEtat">500</x:Double>
    <x:Double x:Key="HauteurCarteEtat">220</x:Double>

    <!--  Boutons principaux  -->
    <x:Double x:Key="LargeurBoutonAction">180</x:Double>
    <x:Double x:Key="HauteurBoutonAction">50</x:Double>

    <!--  En-tête tableau  -->
    <x:Double x:Key="HauteurEnteteTableau">32</x:Double>

    <!--  Marges Accueil  -->
    <Thickness x:Key="MargeTitrePage">40,30,0,0</Thickness>
    <Thickness x:Key="MargeCarteEtat">0,25,0,20</Thickness>
    <Thickness x:Key="MargeTableau">40,0,40,0</Thickness>
    <Thickness x:Key="MargeListe">40,10,40,10</Thickness>
    <Thickness x:Key="MargeBoutonsActions">0,25,0,40</Thickness>

    <!--  Espacement boutons  -->
    <x:Double x:Key="EspacementBoutonsActions">20</x:Double>

</ResourceDictionary>
