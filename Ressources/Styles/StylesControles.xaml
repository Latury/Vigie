<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--  ============================================================  -->
    <!--  1. Bouton principal  -->
    <!--  ============================================================  -->

    <Style x:Key="BoutonPrincipal" TargetType="Button">

        <Setter Property="Background" Value="{StaticResource BrushPrincipale}" />

        <Setter Property="Foreground" Value="{StaticResource BrushTextePrincipal}" />

        <Setter Property="Height" Value="{StaticResource HauteurBoutonStandard}" />

        <Setter Property="CornerRadius" Value="{StaticResource RayonBouton}" />

        <Setter Property="Padding" Value="12,6" />

    </Style>


    <!--  ============================================================  -->
    <!--  2. Bouton secondaire  -->
    <!--  ============================================================  -->

    <Style x:Key="BoutonSecondaire" TargetType="Button">

        <Setter Property="Background" Value="{StaticResource BrushFondCarte}" />

        <Setter Property="Foreground" Value="{StaticResource BrushTextePrincipal}" />

        <Setter Property="Height" Value="{StaticResource HauteurBoutonStandard}" />

        <Setter Property="CornerRadius" Value="{StaticResource RayonBouton}" />

        <Setter Property="BorderBrush" Value="{StaticResource BrushBordure}" />

        <Setter Property="BorderThickness" Value="1" />

        <Setter Property="Padding" Value="12,6" />

    </Style>


    <!--  ============================================================  -->
    <!--  3. Carte UI (panneau principal)  -->
    <!--  ============================================================  -->

    <Style x:Key="CarteUI" TargetType="Border">

        <Setter Property="Background" Value="{StaticResource BrushFondCarte}" />

        <Setter Property="CornerRadius" Value="{StaticResource RayonCarte}" />

        <Setter Property="Padding" Value="{StaticResource EspacementLarge}" />

        <Setter Property="Margin" Value="{StaticResource EspacementStandard}" />

        <Setter Property="BorderBrush" Value="{StaticResource BrushBordure}" />

        <Setter Property="BorderThickness" Value="1" />

    </Style>


    <!--  ============================================================  -->
    <!--  4. Titre principal  -->
    <!--  ============================================================  -->

    <Style x:Key="TexteTitre" TargetType="TextBlock">

        <Setter Property="FontSize" Value="22" />

        <Setter Property="FontWeight" Value="SemiBold" />

        <Setter Property="Foreground" Value="{StaticResource BrushTextePrincipal}" />

        <Setter Property="Margin" Value="{StaticResource EspacementStandard}" />

    </Style>


    <!--  ============================================================  -->
    <!--  5. Texte secondaire  -->
    <!--  ============================================================  -->

    <Style x:Key="TexteSecondaire" TargetType="TextBlock">

        <Setter Property="FontSize" Value="14" />

        <Setter Property="Foreground" Value="{StaticResource BrushTexteSecondaire}" />

    </Style>

</ResourceDictionary>
