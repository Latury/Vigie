<Page
    x:Class="Vigie.Vues.AccueilPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <!--  =============================================================  -->
    <!--  1. LAYOUT PRINCIPAL  -->
    <!--  =============================================================  -->

    <Grid Background="{StaticResource BrushFondPrincipal}">

        <Grid.RowDefinitions>

            <!--  Titre  -->
            <RowDefinition Height="Auto" />

            <!--  Carte état  -->
            <RowDefinition Height="Auto" />

            <!--  Liste logiciels  -->
            <RowDefinition Height="*" />

            <!--  Actions utilisateur  -->
            <RowDefinition Height="Auto" />

        </Grid.RowDefinitions>


        <!--  =============================================================  -->
        <!--  2. TITRE  -->
        <!--  =============================================================  -->

        <StackPanel
            Grid.Row="0"
            Margin="40,30,0,0"
            Spacing="4">

            <TextBlock
                FontSize="26"
                FontWeight="SemiBold"
                Foreground="{StaticResource BrushTextePrincipal}"
                Text="État du système" />

            <TextBlock
                FontSize="14"
                Foreground="{StaticResource BrushTexteSecondaire}"
                Text="{Binding DernierScanTexte}" />

        </StackPanel>


        <!--  =============================================================  -->
        <!--  3. CARTE ÉTAT SYSTÈME  -->
        <!--  =============================================================  -->

        <Border
            Grid.Row="1"
            Width="500"
            Height="220"
            Margin="0,25,0,20"
            HorizontalAlignment="Center"
            Background="{StaticResource BrushFondCarte}"
            BorderBrush="{StaticResource BrushBordure}"
            BorderThickness="1"
            CornerRadius="12">

            <StackPanel
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="18">

                <!--  Indicateur état  -->

                <Grid>

                    <Ellipse
                        Width="110"
                        Height="110"
                        Fill="{StaticResource BrushSucces}"
                        Opacity="0.08" />

                    <Ellipse
                        Width="80"
                        Height="80"
                        Stroke="{StaticResource BrushSucces}"
                        StrokeThickness="4" />

                    <ProgressRing
                        Width="42"
                        Height="42"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        IsActive="{Binding IsScanning}" />

                </Grid>


                <!--  Texte état  -->

                <TextBlock
                    HorizontalAlignment="Center"
                    FontSize="20"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource BrushTextePrincipal}"
                    Text="{Binding TexteEtat}" />


                <!--  Progress mise à jour  -->

                <ProgressRing
                    Width="24"
                    Height="24"
                    IsActive="{Binding IsUpdating}" />

            </StackPanel>

        </Border>


        <!--  =============================================================  -->
        <!--  4. LISTE DES LOGICIELS  -->
        <!--  =============================================================  -->

        <ListView
            Grid.Row="2"
            Margin="40,10,40,10"
            Background="Transparent"
            BorderThickness="0"
            ItemsSource="{Binding Logiciels}">

            <ListView.ItemTemplate>

                <DataTemplate>

                    <Grid Padding="10" ColumnSpacing="20">

                        <Grid.ColumnDefinitions>

                            <!--  Nom  -->
                            <ColumnDefinition Width="*" />

                            <!--  Version actuelle  -->
                            <ColumnDefinition Width="140" />

                            <!--  Nouvelle version  -->
                            <ColumnDefinition Width="140" />

                            <!--  Statut  -->
                            <ColumnDefinition Width="120" />

                        </Grid.ColumnDefinitions>


                        <TextBlock
                            Grid.Column="0"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource BrushTextePrincipal}"
                            Text="{Binding Nom}" />


                        <TextBlock
                            Grid.Column="1"
                            Foreground="{StaticResource BrushTexteSecondaire}"
                            Text="{Binding VersionActuelle}" />


                        <TextBlock
                            Grid.Column="2"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource BrushAccent}"
                            Text="{Binding NouvelleVersion}" />


                        <TextBlock
                            Grid.Column="3"
                            Foreground="{StaticResource BrushTexteSecondaire}"
                            Text="{Binding StatutMiseAJour}" />

                    </Grid>

                </DataTemplate>

            </ListView.ItemTemplate>

        </ListView>


        <!--  =============================================================  -->
        <!--  5. ACTIONS UTILISATEUR  -->
        <!--  =============================================================  -->

        <StackPanel
            Grid.Row="3"
            Margin="0,25,0,40"
            HorizontalAlignment="Center"
            Orientation="Horizontal"
            Spacing="20">

            <!--  Scanner  -->

            <Button
                Width="180"
                Height="50"
                Background="{StaticResource BrushFondCarte}"
                BorderBrush="{StaticResource BrushBordure}"
                BorderThickness="1"
                Command="{Binding ScannerCommande}"
                Content="Scanner"
                Foreground="{StaticResource BrushTextePrincipal}"
                IsEnabled="{Binding PeutScanner}" />


            <!--  Mettre à jour  -->

            <Button
                Width="180"
                Height="50"
                Background="{StaticResource BrushPrincipale}"
                BorderThickness="0"
                Command="{Binding MettreAJourCommande}"
                Content="Mettre à jour"
                Foreground="White"
                IsEnabled="{Binding PeutMettreAJour}" />

        </StackPanel>

    </Grid>

</Page>
