<Page
    x:Class="Vigie.Vues.AccueilPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <!--  =============================  -->
    <!--  1️⃣ LAYOUT PRINCIPAL  -->
    <!--  =============================  -->

    <Grid Background="#F4FAFF">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <!--  Bloc titre  -->

            <RowDefinition Height="Auto" />
            <!--  Carte état  -->

            <RowDefinition Height="*" />
            <!--  Liste logiciels  -->

            <RowDefinition Height="Auto" />
            <!--  Actions  -->
        </Grid.RowDefinitions>

        <!--  =============================  -->
        <!--  2️⃣ BLOC TITRE  -->
        <!--  =============================  -->

        <StackPanel
            Grid.Row="0"
            Margin="40,30,0,0"
            Spacing="4">

            <TextBlock
                FontSize="24"
                FontWeight="SemiBold"
                Foreground="#1F2933"
                Text="État du système" />

            <TextBlock
                FontSize="14"
                Foreground="#6B7280"
                Text="{Binding DernierScanTexte}" />

        </StackPanel>

        <!--  =============================  -->
        <!--  3️⃣ CARTE ÉTAT SYSTÈME  -->
        <!--  =============================  -->

        <Border
            Grid.Row="1"
            Width="480"
            Height="220"
            Margin="0,20,0,20"
            HorizontalAlignment="Center"
            Background="#FFFFFF"
            CornerRadius="12">

            <Border.Shadow>
                <ThemeShadow />
            </Border.Shadow>

            <StackPanel
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="16">

                <Grid>

                    <Ellipse
                        Width="110"
                        Height="110"
                        Fill="#2E7D32"
                        Opacity="0.08" />

                    <Ellipse
                        Width="80"
                        Height="80"
                        Stroke="#2E7D32"
                        StrokeThickness="4" />

                    <ProgressRing
                        Width="40"
                        Height="40"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        IsActive="{Binding IsScanning}"
                        Visibility="{Binding IsScanning, Converter={StaticResource ConvertisseurBooleenVersVisibilite}}" />

                </Grid>

                <TextBlock
                    HorizontalAlignment="Center"
                    FontSize="20"
                    FontWeight="SemiBold"
                    Foreground="#1F2933"
                    Text="{Binding TexteEtat}" />

                <ProgressRing
                    Width="26"
                    Height="26"
                    IsActive="{Binding IsUpdating}"
                    Visibility="{Binding IsUpdating, Converter={StaticResource ConvertisseurBooleenVersVisibilite}}" />

            </StackPanel>

        </Border>

        <!--  =============================  -->
        <!--  4️⃣ LISTE LOGICIELS  -->
        <!--  =============================  -->

        <ListView
            Grid.Row="2"
            Margin="40,10,40,10"
            Background="Transparent"
            BorderThickness="0"
            ItemsSource="{Binding Logiciels}">

            <ListView.ItemTemplate>

                <DataTemplate>

                    <Grid Padding="8" ColumnSpacing="20">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="120" />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            Grid.Column="0"
                            FontWeight="SemiBold"
                            Foreground="#1F2933"
                            Text="{Binding Nom}" />

                        <TextBlock
                            Grid.Column="1"
                            Foreground="#374151"
                            Text="{Binding VersionActuelle}" />

                        <TextBlock
                            Grid.Column="2"
                            FontWeight="SemiBold"
                            Foreground="#2563EB"
                            Text="{Binding NouvelleVersion}" />

                    </Grid>

                </DataTemplate>

            </ListView.ItemTemplate>

        </ListView>

        <!--  =============================  -->
        <!--  5️⃣ ACTIONS UTILISATEUR  -->
        <!--  =============================  -->

        <StackPanel
            Grid.Row="3"
            Margin="0,20,0,40"
            HorizontalAlignment="Center"
            Orientation="Horizontal"
            Spacing="20">

            <Button
                Width="180"
                Height="56"
                Background="#384454"
                BorderThickness="0"
                Command="{Binding ScannerCommande}"
                Content="Scanner"
                Foreground="White"
                IsEnabled="{Binding IsUpdating, Converter={StaticResource ConvertisseurBooleenInverse}}" />

            <Button
                Width="180"
                Height="56"
                Background="#2563EB"
                BorderThickness="0"
                Command="{Binding MettreAJourCommande}"
                Content="Mettre à jour"
                Foreground="White"
                IsEnabled="{Binding IsScanning, Converter={StaticResource ConvertisseurBooleenInverse}}" />

        </StackPanel>

    </Grid>

</Page>
