<Page
    x:Class="Vigie.Vues.AccueilPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <!--  =============================================================  -->
    <!--  1. LAYOUT PRINCIPAL  -->
    <!--  =============================================================  -->

    <Grid Background="{StaticResource BrushFondPrincipal}">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>


        <!--  =============================================================  -->
        <!--  2. TITRE PAGE  -->
        <!--  =============================================================  -->

        <StackPanel
            Grid.Row="0"
            Margin="{StaticResource MargeTitrePage}"
            Spacing="4">

            <TextBlock
                FontSize="26"
                FontWeight="SemiBold"
                Foreground="{StaticResource BrushTextePrincipal}"
                Text="État du système" />

            <TextBlock
                FontSize="14"
                Foreground="{StaticResource BrushTexteSecondaire}"
                Text="{Binding DernierScanTexte}" />

        </StackPanel>


        <!--  =============================================================  -->
        <!--  3. CARTE ÉTAT SYSTÈME  -->
        <!--  =============================================================  -->

        <Border
            Grid.Row="1"
            Width="{StaticResource LargeurCarteEtat}"
            Height="{StaticResource HauteurCarteEtat}"
            Margin="{StaticResource MargeCarteEtat}"
            HorizontalAlignment="Center"
            Background="{StaticResource BrushFondCarte}"
            BorderBrush="{StaticResource BrushBordure}"
            BorderThickness="1"
            CornerRadius="12">

            <StackPanel
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="18">

                <Grid>

                    <Ellipse
                        Width="110"
                        Height="110"
                        Fill="{StaticResource BrushSucces}"
                        Opacity="0.08" />

                    <Ellipse
                        Width="80"
                        Height="80"
                        Stroke="{StaticResource BrushSucces}"
                        StrokeThickness="4" />

                    <ProgressRing
                        Width="42"
                        Height="42"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        IsActive="{Binding IsScanning}" />

                </Grid>

                <TextBlock
                    HorizontalAlignment="Center"
                    FontSize="20"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource BrushTextePrincipal}"
                    Text="{Binding TexteEtat}" />

                <ProgressRing
                    Width="24"
                    Height="24"
                    IsActive="{Binding IsUpdating}" />

            </StackPanel>

        </Border>


        <!--  =============================================================  -->
        <!--  4. ENTÊTE TABLEAU  -->
        <!--  =============================================================  -->

        <Grid
            Grid.Row="2"
            Height="{StaticResource HauteurEnteteTableau}"
            Margin="{StaticResource MargeTableau}">

            <Grid.ColumnDefinitions>

                <ColumnDefinition Width="90" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="120" />
                <ColumnDefinition Width="40" />
                <ColumnDefinition Width="140" />
                <ColumnDefinition Width="120" />

            </Grid.ColumnDefinitions>

            <TextBlock
                Grid.Column="0"
                FontWeight="SemiBold"
                Text="Source" />

            <CheckBox
                Grid.Column="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                IsChecked="{Binding ToutSelectionner, Mode=TwoWay}"
                IsThreeState="True" />

            <TextBlock
                Grid.Column="2"
                FontWeight="SemiBold"
                Text="Nom" />

            <TextBlock
                Grid.Column="3"
                HorizontalAlignment="Center"
                FontWeight="SemiBold"
                Text="Version actuelle" />

            <TextBlock
                Grid.Column="5"
                HorizontalAlignment="Center"
                FontWeight="SemiBold"
                Text="Nouvelle version" />

            <TextBlock
                Grid.Column="6"
                HorizontalAlignment="Center"
                FontWeight="SemiBold"
                Text="Statut" />

        </Grid>


        <!--  =============================================================  -->
        <!--  5. SÉPARATEUR  -->
        <!--  =============================================================  -->

        <Border
            Grid.Row="2"
            Height="1"
            Margin="40,30,40,0"
            VerticalAlignment="Bottom"
            Background="{StaticResource BrushBordure}" />


        <!--  =============================================================  -->
        <!--  6. LISTE DES LOGICIELS  -->
        <!--  =============================================================  -->

        <ListView
            Grid.Row="3"
            Margin="{StaticResource MargeListe}"
            Background="Transparent"
            BorderThickness="0"
            ItemsSource="{Binding Logiciels}">

            <ListView.ItemContainerStyle>

                <Style TargetType="ListViewItem">

                    <Setter Property="Padding" Value="0" />
                    <Setter Property="Margin" Value="0" />
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="VerticalContentAlignment" Value="Center" />
                    <Setter Property="Background" Value="Transparent" />

                </Style>

            </ListView.ItemContainerStyle>


            <ListView.ItemTemplate>

                <DataTemplate>

                    <Grid>

                        <Grid.ColumnDefinitions>

                            <ColumnDefinition Width="90" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="40" />
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="120" />

                        </Grid.ColumnDefinitions>


                        <TextBlock
                            Grid.Column="0"
                            Foreground="{StaticResource BrushTexteSecondaire}"
                            Text="{Binding Source}" />


                        <CheckBox
                            Grid.Column="1"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            IsChecked="{Binding EstSelectionne, Mode=TwoWay}"
                            IsEnabled="{Binding SelectionAutorisee}"
                            IsHitTestVisible="{Binding SelectionAutorisee}"
                            Opacity="{Binding SelectionAutorisee, Converter={StaticResource ConvertisseurBooleenInverse}}" />


                        <TextBlock
                            Grid.Column="2"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource BrushTextePrincipal}"
                            Text="{Binding Nom}" />


                        <TextBlock
                            Grid.Column="3"
                            HorizontalAlignment="Center"
                            Foreground="{StaticResource BrushTexteSecondaire}"
                            Text="{Binding VersionActuelle}"
                            TextAlignment="Center" />


                        <TextBlock
                            Grid.Column="4"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Foreground="{StaticResource BrushTexteSecondaire}"
                            Text="→" />


                        <TextBlock
                            Grid.Column="5"
                            HorizontalAlignment="Center"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource BrushAccent}"
                            Text="{Binding NouvelleVersion}"
                            TextAlignment="Center" />


                        <TextBlock
                            Grid.Column="6"
                            HorizontalAlignment="Center"
                            Foreground="{Binding StatutMiseAJour, Converter={StaticResource ConvertisseurStatutCouleur}}"
                            Text="{Binding StatutMiseAJour}"
                            TextAlignment="Center" />

                    </Grid>

                </DataTemplate>

            </ListView.ItemTemplate>

        </ListView>


        <!--  =============================================================  -->
        <!--  7. ACTIONS UTILISATEUR  -->
        <!--  =============================================================  -->

        <StackPanel
            Grid.Row="4"
            Margin="{StaticResource MargeBoutonsActions}"
            HorizontalAlignment="Center"
            Orientation="Horizontal"
            Spacing="{StaticResource EspacementBoutonsActions}">

            <Button
                Width="{StaticResource LargeurBoutonAction}"
                Height="{StaticResource HauteurBoutonAction}"
                Background="{StaticResource BrushFondCarte}"
                BorderBrush="{StaticResource BrushBordure}"
                BorderThickness="1"
                Command="{Binding ScannerCommande}"
                Content="Scanner"
                Foreground="{StaticResource BrushTextePrincipal}"
                IsEnabled="{Binding PeutScanner}" />

            <Button
                Width="{StaticResource LargeurBoutonAction}"
                Height="{StaticResource HauteurBoutonAction}"
                Background="{StaticResource BrushPrincipale}"
                BorderThickness="0"
                Command="{Binding MettreAJourCommande}"
                Content="Mettre à jour"
                Foreground="White"
                IsEnabled="{Binding PeutMettreAJour}" />

        </StackPanel>

    </Grid>

</Page>
