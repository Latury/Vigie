<Window
    x:Class="Vigie.FenetrePrincipale"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Vigie"
    mc:Ignorable="d">

    <!--  =============================================================  -->
    <!--  Backdrop système (effet Mica Windows 11)  -->
    <!--  =============================================================  -->

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <!--  =============================================================  -->
    <!--  1. LAYOUT PRINCIPAL  -->
    <!--  =============================================================  -->

    <Grid>

        <Grid.ColumnDefinitions>

            <!--  Barre navigation  -->
            <ColumnDefinition Width="{StaticResource LargeurSidebar}" />

            <!--  Zone contenu  -->
            <ColumnDefinition Width="*" />

        </Grid.ColumnDefinitions>

        <!--  =============================================================  -->
        <!--  2. BARRE LATÉRALE DE NAVIGATION  -->
        <!--  =============================================================  -->

        <Grid Grid.Column="0" Background="{StaticResource CouleurSidebar}">

            <!--  =========================================================  -->
            <!--  Styles navigation  -->
            <!--  =========================================================  -->

            <Grid.Resources>

                <Style x:Key="NavButtonStyle" TargetType="Button">

                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="Foreground" Value="White" />
                    <Setter Property="BorderThickness" Value="0" />
                    <Setter Property="HorizontalAlignment" Value="Stretch" />

                    <Setter Property="Height" Value="{StaticResource HauteurBoutonNavigation}" />

                    <Setter Property="Margin" Value="{StaticResource MargeNavigationBouton}" />

                    <Setter Property="HorizontalContentAlignment" Value="Left" />

                    <Setter Property="Padding" Value="12,0" />

                    <Setter Property="Template">

                        <Setter.Value>

                            <ControlTemplate TargetType="Button">

                                <Grid x:Name="RootGrid" Background="Transparent">
                                    <ContentPresenter Margin="12,0" VerticalAlignment="Center" />

                                    <VisualStateManager.VisualStateGroups>

                                        <VisualStateGroup x:Name="CommonStates">

                                            <VisualState x:Name="Normal" />

                                            <VisualState x:Name="PointerOver">

                                                <Storyboard>

                                                    <ColorAnimation
                                                        Storyboard.TargetName="RootGrid"
                                                        Storyboard.TargetProperty="(Grid.Background).(SolidColorBrush.Color)"
                                                        To="{StaticResource CouleurSidebarHover}"
                                                        Duration="0" />

                                                </Storyboard>

                                            </VisualState>

                                            <VisualState x:Name="Pressed">

                                                <Storyboard>

                                                    <ColorAnimation
                                                        Storyboard.TargetName="RootGrid"
                                                        Storyboard.TargetProperty="(Grid.Background).(SolidColorBrush.Color)"
                                                        To="{StaticResource CouleurSidebarPressed}"
                                                        Duration="0" />

                                                </Storyboard>

                                            </VisualState>

                                        </VisualStateGroup>

                                    </VisualStateManager.VisualStateGroups>
                                </Grid>

                            </ControlTemplate>

                        </Setter.Value>

                    </Setter>

                </Style>

            </Grid.Resources>

            <!--  =========================================================  -->
            <!--  Boutons navigation  -->
            <!--  =========================================================  -->

            <StackPanel
                Margin="{StaticResource MargeSidebar}"
                VerticalAlignment="Top"
                Spacing="{StaticResource EspacementNavigation}">

                <Button
                    Click="Accueil_Click"
                    Content="Accueil"
                    Style="{StaticResource NavButtonStyle}" />

                <Button
                    Click="Historique_Click"
                    Content="Historique"
                    Style="{StaticResource NavButtonStyle}" />

                <Button
                    Click="Parametres_Click"
                    Content="Paramètres"
                    Style="{StaticResource NavButtonStyle}" />

                <Button
                    Click="APropos_Click"
                    Content="À propos"
                    Style="{StaticResource NavButtonStyle}" />

            </StackPanel>

        </Grid>

        <!--  =============================================================  -->
        <!--  3. CONTENU PRINCIPAL (FRAME NAVIGATION)  -->
        <!--  =============================================================  -->

        <Frame x:Name="RootFrame" Grid.Column="1" />

    </Grid>

</Window>
